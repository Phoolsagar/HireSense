# Render environment variables for HireSense
# Fill real values in Render Dashboard -> Environment before first deploy

HIRESENSE_APP_NAME=HireSense

# Use external MySQL provider credentials here
HIRESENSE_DB_URL=jdbc:mysql://<DB_HOST>:<DB_PORT>/<DB_NAME>?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
HIRESENSE_DB_USERNAME=<DB_USERNAME>
HIRESENSE_DB_PASSWORD=<DB_PASSWORD>

# Gmail SMTP credentials
HIRESENSE_MAIL_USERNAME=your_email@gmail.com
HIRESENSE_MAIL_PASSWORD=your_gmail_app_password
