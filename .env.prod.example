# Copy to .env.prod on your VPS and fill values
HIRESENSE_APP_NAME=HireSense

# Database user used by both app and MySQL container
HIRESENSE_DB_USERNAME=hiresense
HIRESENSE_DB_PASSWORD=change_me_strong_password
MYSQL_ROOT_PASSWORD=change_me_strong_root_password

# Mail settings
HIRESENSE_MAIL_USERNAME=your_email@gmail.com
HIRESENSE_MAIL_PASSWORD=your_gmail_app_password
