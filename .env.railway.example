# Railway app service variables
HIRESENSE_APP_NAME=HireSense
HIRESENSE_MAIL_USERNAME=your_email@gmail.com
HIRESENSE_MAIL_PASSWORD=your_gmail_app_password

# Use Railway MySQL service values
# Example source values in Railway MySQL service:
# MYSQLHOST, MYSQLPORT, MYSQLDATABASE, MYSQLUSER, MYSQLPASSWORD
HIRESENSE_DB_URL=jdbc:mysql://MYSQLHOST:MYSQLPORT/MYSQLDATABASE?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
HIRESENSE_DB_USERNAME=MYSQLUSER
HIRESENSE_DB_PASSWORD=MYSQLPASSWORD
